{
  "name": "dashboard-admin",
  "version": "1.0.0",
  "description": "Dashboard Admin - React Frontend + Vercel Serverless API",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n \"server,client\" -c \"yellow,cyan\" \"npm run server\" \"npm run client\"",
    "server": "node server/app.js",
    "client": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "start": "node server/app.js"
  },
  "keywords": [
    "vite",
    "react",
    "vercel",
    "dashboard",
    "mongodb"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "chalk": "^5.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "framer-motion": "^12.23.26",
    "lucide-react": "^0.561.0",
    "mongoose": "^8.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^3.2.29",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
